# Development Environment Variables


# ─── Server ────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:1323
SERVER_PORT=1323
ENV=development
LOG_LEVEL=debug
TimeZone=Asia/Jakarta


# ─── Default ───────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
DEFAULT_PASSWORD=password123


# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOW_ORIGINS=*
ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOW_HEADERS=Content-Type,Authorization
ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400


# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/neosim_go_dev_db?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=subian_go_dev_db
DB_SSL_MODE=disable


# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=2tJxwtdlPVwjN92YJSDUMp9+PlZ/Iy48
JWT_ISSUER=subiango
JWT_ACCESS_TOKEN_EXP_MINUTES=10080 #1440 x 7hari
JWT_REFRESH_TOKEN_EXP_DAYS=7

# ─── Login Security ────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_MINUTES=5
MAX_CONCURRENT_SESSIONS=5
RATE_LIMIT_LOGIN_PER_IP_PER_MINUTE=20

# ─── Password Policy ───────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=6
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SYMBOL=false
PASSWORD_HISTORY_COUNT=3

# ─── Registration ──────────────────────────────────────────────────────────────
IS_REGISTRATION_ACTIVE=true
AUTO_ACTIVE_USER=true

# ─── SMTP (Email) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=SubianGO

# ─── Reset Password ────────────────────────────────────────────────────────────
MAIL_RESET_TOKEN_EXP_MINUTES=30

