
# ─── Server ────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:1323
SERVER_PORT=8080
ENV=production
APP_FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info


# ─── Default ───────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=10
DEFAULT_PASSWORD=password123


# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOW_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOW_HEADERS=Content-Type,Authorization
ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=subian_go_prod_db
DB_SSL_MODE=disable


# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-here
JWT_ISSUER=subian
JWT_ACCESS_TOKEN_EXP_MINUTES=15
JWT_REFRESH_TOKEN_EXP_DAYS=7

# ─── Login Security ────────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_DURATION_MINUTES=15
MAX_CONCURRENT_SESSIONS=5
RATE_LIMIT_LOGIN_PER_IP_PER_MINUTE=20

# ─── Password Policy ───────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=6
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SYMBOL=false
PASSWORD_HISTORY_COUNT=3

# ─── Registration ──────────────────────────────────────────────────────────────
IS_REGISTRATION_ACTIVE=true
AUTO_ACTIVE_USER=true

# ─── SMTP (Email) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Subian

# ─── Reset Password ────────────────────────────────────────────────────────────
MAIL_RESET_TOKEN_EXP_MINUTES=30